			type="hidden" class="uploaded-filename" name="images_filenames[{{ image.getIdentifier() }}]" value="{{ imageForm.vars.data.picture }}">

			{# ✅ Correction: 👉 🔥 utilisation d'un identifiant métier pour les images supprimées #}
			<input type="hidden" class="removed-image" name="removed_images[]" value="{{ imageForm.vars.data.getIdentifier() }}">

			<div class="media-actions flex justify-end gap-2 mt-2">
				<div class="flex flex-row-reverse items-center gap-2">
