							{{ trick.title ?: 'Titre du trick' }}
						</h1>
					</div>

					{# Champ file Symfony #}
					{{ form_widget(form.featuredImage, {
                        attr: {
                            class: 'hidden',
                            accept: 'image/png, image/jpeg, image/webp',
                            id: 'featured-input'
                        }
                    }) }}

