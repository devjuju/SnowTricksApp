							<div id="video-wrapper" class="
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																grid
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																grid-cols-1
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																gap-6
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:flex
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:flex-row
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:gap-4
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:overflow-x-auto
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:scroll-smooth
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																md:snap-x md:snap-mandatory">

								{% for videoForm in form.videos %}
									<div class="media-item media-video relative w-full md:w-40 md:flex-shrink-0 md:snap-start" data-video-id="{{ videoForm.vars.data.getIdentifier() }}">
										<div class="mb-3 w-full aspect-video rounded border relative">
											<iframe src="{{ videoForm.vars.data.getEmbedUrl()|default('') }}" class="w-full h-full rounded border"></iframe>
											<div class="video-placeholder absolute inset-0 bg-gray-100 flex items-center justify-center rounded border {{ videoForm.vars.data.getEmbedUrl() ? 'hidden' : '' }}">
												<i class="bi bi-play-btn text-3xl text-gray-400"></i>
											</div>
										</div>

										<input type="hidden" class="removed-video" name="removed_videos[]">

										<div class="media-actions flex justify-end gap-2 mt-2">
											<div class="flex flex-row-reverse items-center gap-2">
												<button type="button" class="remove-item p-2 rounded bg-[#f8285a] text-white hover:bg-[#d81a48] hover:border-[#d81a48]">
													<i class="bi bi-trash3-fill"></i>
													<span class="sr-only">Remove</span>
												</button>

												<button type="button" class="item-add p-2 rounded border bg-[#2563eb] hover:bg-[#1f40ae]">
													<i class="bi bi-pencil-fill"></i>
													<span class="sr-only">Add</span>
												</button>

												<button type="button" class="item-edit hidden p-2 rounded bg-[#2563eb] hover:bg-[#1f40ae] text-white">
													<i class="bi bi-pencil-fill"></i>
													<span class="sr-only">Edit</span>
												</button>

												<button type="button" class="item-close hidden p-2 rounded border border-[#f6c000] text-[#f6c000]">
													<i class="bi bi-eye-slash-fill"></i>
													<span class="sr-only">Close</span>
												</button>

												{{ form_widget(videoForm.url, {attr:{class:'item-input w-0 opacity-0 transition-all duration-300'}}) }}
											</div>
										</div>
									</div>
								{% endfor %}

							</div>


							<div class="mt-4">
								<button type="button" id="add-video" class="w-full px-4 py-2 bg-[#f1f1f4] text-[#2663eb] hover:bg-[#e6e6e6] rounded-2xl hover:text-[#2663eb] font-semibold transition-all duration-300 uppercase border border-[#c4cada]">
									Ajouter une vidéo
								</button>
							</div>


						</div>


					</div>

					{# ---------------- PROTOTYPES CACHÉS ---------------- #}
					<template id="image-prototype">
						{{ imagePrototype|raw }}
					</template>

					<template id="video-prototype">
						{{ videoPrototype|raw }}
					</template>

				</div>

				<!-- Title, Content, Category -->
				<div class="px-4 md:px-8 lg:px-24">
					<div class="mb-4">
						{{ form_widget(form.title, {
                            attr: {
                                class: 'w-full rounded-xl border border-[#1b84ff]  bg-[white] px-4 py-2',
                            }
                        }) }}
						<div class="text-[#d81a48] text-sm">{{ form_errors(form.title) }}</div>
					</div>
					<div class="mb-4">
						{{ form_widget(form.content, {
                            attr: {
                                class: 'w-full h-28 sm:h-36 rounded-xl border border-[#1b84ff]  bg-white px-4 py-2 ',
                            }
                        }) }}
						<div class="text-[#d81a48] text-sm">{{ form_errors(form.content) }}</div>
					</div>
					<div class="mb-4">
						{{ form_widget(form.category, {
                            attr: {
                                class: ' rounded-xl border border-[#1b84ff]  bg-white px-4 py-2  px-4 pr-10 py-2 ',
                            }
                        }) }}
						<div class="text-[#d81a48] text-sm">{{ form_errors(form.category) }}</div>
					</div>
					<div class="flex justify-end mt-4 gap-4">

						{{ form_row(form.delete) }}
						{{ form_row(form.save) }}
					</div>
					{# Token CSRF #}

				</div>

				{{ form_widget(form._token) }}
				{{ form_end(form, { render_rest: false }) }}
