											<button type="button" class="item-edit hidden p-2 bg-blue-600 text-white rounded">
												<i class="bi bi-pencil-fill"></i>
											</button>

											<button type="button" class="item-close hidden p-2 border border-yellow-400 text-yellow-400 rounded">
												<i class="bi bi-eye-slash-fill"></i>
											</button>

											{{ form_widget(imageForm.file, {
                attr: {
                    class: 'item-input w-0 opacity-0',
                    accept: 'image/png,image/jpeg,image/webp'
                }
            }) }}

										</div>
									</div>

								{% endfor %}

							</div>

							<div class="mt-4">
								<button type="button" id="add-image" class="w-full px-4 py-2 bg-[#f1f1f4] text-[#2663eb] hover:bg-[#e6e6e6] rounded-2xl hover:text-[#2663eb] font-semibold transition-all duration-300 uppercase border border-[#c4cada]">
									Ajouter une image
								</button>
							</div>

						</div>
						{# ========== VIDEOS =========== #}
