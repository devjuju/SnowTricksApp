										<div class="mb-3 w-full aspect-video rounded overflow-hidden border relative">

											<img src="{{ asset('uploads/images/' ~ image.picture) }}" class="image-preview w-full h-full object-cover" data-publicid="{{ image.publicId }}">

											<div class="image-placeholder hidden absolute inset-0 bg-gray-100 flex items-center justify-center">
												<i class="bi bi-image text-2xl text-gray-400"></i>
											</div>
										</div>

										{# 🔥 ONLY ONE SOURCE OF TRUTH #}
										<input type="hidden" class="uploaded-publicid" value="{{ image.publicId }}">

										<div class="media-actions flex justify-end gap-2 mt-2">
											<div class="flex flex-row-reverse items-center gap-2">
												<button type="button" class="remove-item p-2 rounded bg-[#f8285a] text-white hover:bg-[#d81a48] hover:border-[#d81a48]">
													<i class="bi bi-trash3-fill"></i>
													<span class="sr-only">Remove</span>
												</button>

												<button type="button" class="item-add p-2 rounded border border-[#2563eb] bg-[#2563eb] text-white hover:bg-[#1e40af] hover:text-white transition">
													<i class="bi bi-pencil-fill"></i>
													<span class="sr-only">Add</span>
												</button>

												<button type="button" class="item-edit p-2 rounded border border-[#2563eb] text-white hover:bg-[#1f40ae] hover:text-white transition hidden bg-[#2563eb] hover:border-[#1f40ae]">
