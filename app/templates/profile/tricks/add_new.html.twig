						<button type="button" id="edit-featured" class="p-2 rounded bg-[#2563eb] hover:bg-[#1e40af] text-white shadow-lg">
							<i class="bi bi-pencil-fill"></i>
							<span class="sr-only">Edit</span>
						</button>
						<button type="button" id="delete-featured" class="p-2 rounded bg-[#f8285a] text-white hover:bg-[#d81a48] shadow-lg">
							<i class="bi bi-trash3-fill"></i>
							<span class="sr-only">Delete</span>
						</button>
					</div>
					{# Champ caché suppression (backend) #}
					{{ form_widget(form.deleteFeaturedImage) }}
				</div>


				{# Erreur validation #}
				<div id="featured-error" class="text-red-500 text-sm px-4 md:px-8 lg:px-8 mt-4">{{ form_errors(form.featuredImage) }}</div>

				<div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col gap-3"></div>

